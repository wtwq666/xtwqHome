# 复制为 backend/.env（勿提交真实密钥）

# PostgreSQL RDS
PG_HOST=your-instance.pg.rds.aliyuncs.com
PG_PORT=5432
PG_DATABASE=tutusys
PG_USER=your_user
PG_PASSWORD=your_password

# 或单行覆盖：DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/tutu

# 阿里云 OSS（SDK 读取 OSS_ACCESS_KEY_ID / OSS_ACCESS_KEY_SECRET）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
STORAGE_BACKEND=oss
OSS_BUCKET=coucou-oss
OSS_REGION=cn-guangzhou
OSS_PREFIX=rabbit/

# 本地开发可改回：STORAGE_BACKEND=local

# 含 Vercel 前端域名，例如 https://your-app.vercel.app
# 腾讯云直连示例：http://129.211.3.207:8000（仅测试；Vercel 正式环境需 HTTPS API）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app,http://129.211.3.207:8000
